{
  "entities": {
    "siteSettings": {
      "title": "Site Settings",
      "description": "General site-wide settings",
      "type": "object",
      "properties": {
        "businessName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "googleMapsUrl": { "type": "string" },
        "instagramUrl": { "type": "string" },
        "facebookUrl": { "type": "string" }
      }
    },
    "homepage": {
      "title": "Homepage Content",
      "description": "Content for the landing page",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "featuredText": { "type": "string" },
        "banners": { "type": "array", "items": { "type": "string" } },
        "campaignImages": { "type": "array", "items": { "type": "string" } }
      }
    },
    "collection": {
      "title": "Collection",
      "description": "A group of related products",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name"]
    },
    "product": {
      "title": "Product",
      "description": "A fashion item for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "collectionName": { "type": "string" },
        "sku": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "fabric": { "type": "string" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "careInstructions": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "price", "category"]
    },
    "policy": {
      "title": "Policy",
      "description": "Legal or operational policy document",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "pdfUrl": { "type": "string" }
      },
      "required": ["title"]
    },
    "media": {
      "title": "Media Asset",
      "description": "An uploaded file in the media library",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url"]
    }
  },
  "firestore": {
    "/siteSettings/config": { "schema": "siteSettings", "description": "Site-wide configuration" },
    "/homepage/content": { "schema": "homepage", "description": "Homepage content" },
    "/collections/{collectionId}": { "schema": "collection", "description": "Product collections" },
    "/products/{productId}": { "schema": "product", "description": "Product catalog" },
    "/policies/{policyId}": { "schema": "policy", "description": "Legal and operational policies" },
    "/media/{mediaId}": { "schema": "media", "description": "Media library assets" }
  }
}
